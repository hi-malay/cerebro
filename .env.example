GROQ_API_KEY=your_groq_api_key
TAVILY_API_KEY=your_tavily_api_key
NEO_URL=neo4j+s://xxxxx.databases.neo4j.io
NEO_USER=your_neo4j_user
NEO_PASSWORD=your_neo4j_password
# Optional: leave unset to use the Neo4j account's home database
# NEO_DATABASE=your_database_name
QDRANT_URL=https://your-qdrant-host
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=pdf_docs
PORT=8001
